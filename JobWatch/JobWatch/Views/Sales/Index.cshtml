@model List<JobWatch.Models.Job>
@{
    ViewData["Title"] = "Sales";
}

<h2>Sales Jobs</h2>

@if (User.IsInRole("Admin") && User.HasClaim("Department", "Sales"))
{
    <a asp-controller="Sales" asp-action="AddSales" class="btn btn-primary mb-3">Add Job</a>
}

@if (Model.Count == 0)
{
    <p>No sales jobs found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in Model)
            {
                <tr>
                    <td>@job.Name</td>
                    <td>@job.Description</td>
                </tr>
            }
        </tbody>
    </table>
}
