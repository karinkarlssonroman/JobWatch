@model List<Job>
@{
    ViewData["Title"] = "Jobs";
}

<h1>Jobs</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Job</a>
</p>

@if (Model.Count == 0)
{
    <p>No jobs found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in Model)
            {
                <tr>
                    <td>@job.Name</td>
                    <td>@job.Description</td>
                </tr>
            }
        </tbody>
    </table>
}
